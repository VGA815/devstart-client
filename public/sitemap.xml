<?xml version="1.0" encoding="UTF-8"?>
<!--
  Static public routes only. The __SITE_URL__ host is substituted at build time
  (SITE_URL build-arg; see Dockerfile / Makefile). Dynamic entity URLs
  (/startups/:id, /investors/:id, /experts/:id, /profile/:id) should be appended
  by a build- or deploy-time generator that reads them from the API.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>__SITE_URL__/</loc>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>__SITE_URL__/startups</loc>
    <changefreq>daily</changefreq>
    <priority>0.9</priority>
  </url>
  <url>
    <loc>__SITE_URL__/investors</loc>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>
  <url>
    <loc>__SITE_URL__/experts</loc>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>
  <url>
    <loc>__SITE_URL__/plans</loc>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>
</urlset>
